---
import '../styles/global.css';

// Self-hosted fonts — latin subsets only (smaller bundles than full unicode ranges)
import '@fontsource/allura/latin-400.css';
import '@fontsource/manrope/latin-300.css';
import '@fontsource/manrope/latin-400.css';
import '@fontsource/manrope/latin-500.css';
import '@fontsource/manrope/latin-600.css';
import '@fontsource/manrope/latin-700.css';
import '@fontsource/syne/latin-400.css';
import '@fontsource/syne/latin-500.css';
import '@fontsource/syne/latin-600.css';
import '@fontsource/syne/latin-700.css';
import '@fontsource/syne/latin-800.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Queen Cannabis — Restaurant & Lounge · Rawai, Phuket',
  description = 'Restaurant, lounge, and premium cannabis in Rawai — open daily 8 AM to 2 AM.',
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#0a0612" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#fff5fb" media="(prefers-color-scheme: light)" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
  </head>
  <body>
    <slot />
  </body>
</html>
